{
  "contract": "ryan.suite.service/1",
  "cases": [
    {
      "id": "valid_uoink",
      "expected_valid": true,
      "context": {
        "expected_service": "uoink"
      },
      "payload": {
        "ok": true,
        "contract": "ryan.suite.service",
        "version": 1,
        "service": {
          "id": "uoink",
          "name": "Uoink",
          "service_version": "3.6.0",
          "api_version": 1,
          "resident": true,
          "default_port": 5179,
          "health": {
            "contract": "ryan.suite.health",
            "version": 1,
            "href": "/api/suite/v1/health"
          },
          "capabilities": [
            "uoink.corpus.read/1",
            "uoink.engagement.ingest/1",
            "uoink.media.handoff/1"
          ],
          "ui": {
            "home": "/dashboard",
            "routes": {
              "library": "/dashboard#library"
            }
          },
          "mcp": {
            "name": "uoink",
            "transport": "stdio"
          }
        }
      }
    },
    {
      "id": "valid_writer",
      "expected_valid": true,
      "context": {
        "expected_service": "writer"
      },
      "payload": {
        "ok": true,
        "contract": "ryan.suite.service",
        "version": 1,
        "service": {
          "id": "writer",
          "name": "Writer",
          "service_version": "0.1.0",
          "api_version": 1,
          "resident": true,
          "default_port": 5181,
          "health": {
            "contract": "ryan.suite.health",
            "version": 1,
            "href": "/api/suite/v1/health"
          },
          "capabilities": [
            "writer.api/1",
            "writer.shot-list/1"
          ],
          "ui": {
            "home": "/",
            "routes": {}
          },
          "mcp": {
            "name": "writer",
            "transport": "stdio"
          }
        }
      }
    },
    {
      "id": "wrong_service",
      "base": "valid_uoink",
      "expected_valid": false,
      "mutations": [
        {
          "op": "set",
          "path": ["service", "id"],
          "value": "writer"
        }
      ]
    },
    {
      "id": "wrong_version",
      "base": "valid_uoink",
      "expected_valid": false,
      "mutations": [
        {
          "op": "set",
          "path": ["version"],
          "value": 2
        }
      ]
    },
    {
      "id": "unknown_key",
      "base": "valid_uoink",
      "expected_valid": false,
      "mutations": [
        {
          "op": "set",
          "path": ["unexpected"],
          "value": true
        }
      ]
    },
    {
      "id": "command_field",
      "base": "valid_uoink",
      "expected_valid": false,
      "mutations": [
        {
          "op": "set",
          "path": ["service", "mcp", "command"],
          "value": "python -m uoink"
        }
      ]
    },
    {
      "id": "token_field",
      "base": "valid_uoink",
      "expected_valid": false,
      "mutations": [
        {
          "op": "set",
          "path": ["token"],
          "value": "synthetic-forbidden-token"
        }
      ]
    }
  ]
}
